# ────────────────────────────────────────────────────────────────────────────
# NIDHI App Secrets Configuration Template
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to secrets.properties and fill in your actual API keys.
# NEVER commit secrets.properties to version control!
# ────────────────────────────────────────────────────────────────────────────

# Groq API (OpenAI-compatible, fast inference)
# Get keys at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1/

# Supabase (Backend & Database)
# Get keys at: https://app.supabase.com/projects
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Clerk (Authentication)
# Get keys at: https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_here

# Firebase (already in google-services.json)
# but you can override here if needed
FIREBASE_PROJECT_ID=your_project_id

# ────────────────────────────────────────────────────────────────────────────
# Setup Instructions:
# ────────────────────────────────────────────────────────────────────────────
# 1. Rename this file to secrets.properties
# 2. Fill in your actual API keys from each service
# 3. Add secrets.properties to .gitignore (if not already there)
# 4. Run: ./gradlew assembleDebug
# 5. The build will automatically inject these into BuildConfig
# ────────────────────────────────────────────────────────────────────────────
